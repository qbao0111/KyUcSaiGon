  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 203819ab822436f49856dc13c1fc20ee, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BenThanhSceneController
  memoryZone: {fileID: 1743239873}
  marketVendor: {fileID: 1818075339}
  oldConicalHatItem: {fileID: 874732168}
  fruitBasketPuzzle: {fileID: 599000391}
  returnBusStop: {fileID: 1734039586}
  objectiveEnterMarket: "\u0110i v\xE0o khu ch\u1EE3 v\xE0 t\xECm ng\u01B0\u1EDDi
    \u0111ang gi\u1EEF k\xFD \u1EE9c n\u01A1i n\xE0y."
  objectiveFindHat: "T\xECm chi\u1EBFc n\xF3n l\xE1 c\u0169 quanh khu ch\u1EE3."
  objectiveReturnVendor: "Mang k\xFD \u1EE9c tr\u1EDF l\u1EA1i cho c\xF4 b\xE1n h\xE0ng."
  objectiveSolvePuzzle: "Gi\u1EA3i c\xE2u \u0111\u1ED1 gi\u1ECF tr\xE1i c\xE2y."
  objectiveReturnBus: "\u0110i \u0111\u1EBFn tr\u1EA1m xe bu\xFDt k\xFD \u1EE9c \u0111\u1EC3
    quay l\u1EA1i h\xE0nh tr\xECnh."
  firstVendorDialogue: "Ng\xE0y x\u01B0a khu ch\u1EE3 n\xE0y l\xFAc n\xE0o c\u0169ng
    \u0111\u1EA7y ti\u1EBFng rao v\xE0 b\u01B0\u1EDBc ch\xE2n. Nh\u01B0ng gi\u1EDD
    m\u1ECDi th\u1EE9 im qu\xE1... C\xF3 l\u1EBD k\xFD \u1EE9c n\u1EB1m \u1EDF \u0111\xE2u
    \u0111\xF3 quanh \u0111\xE2y."
  secondVendorDialogue: "\u0110\xFAng r\u1ED3i... chi\u1EBFc n\xF3n n\xE0y t\u1EEBng
    \u0111i c\xF9ng bi\u1EBFt bao bu\u1ED5i ch\u1EE3 s\u1EDBm. Nh\u01B0ng \xE2m thanh
    c\u1EE7a khu ch\u1EE3 v\u1EABn ch\u01B0a tr\u1EDF l\u1EA1i. H\xE3y s\u1EAFp x\u1EBFp
    l\u1EA1i gi\u1ECF tr\xE1i c\xE2y."
  restoredDialogue: "Ti\u1EBFng rao v\xE0 nh\u1ECBp s\u1ED1ng tr\u1EDF l\u1EA1i.
    Ch\u1EE3 B\u1EBFn Th\xE0nh \u0111\xE3 \u0111\u01B0\u1EE3c kh\xF4i ph\u1EE5c."
