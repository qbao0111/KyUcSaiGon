  objectiveFindMap: "\u0110i \u0111\u1EBFn c\u1ED5ng Dinh v\xE0 t\xECm m\u1EA3nh
    b\u1EA3n \u0111\u1ED3 l\u1ECBch s\u1EED."
  objectiveReturnNpc: "\u0110\u01B0a m\u1EA3nh b\u1EA3n \u0111\u1ED3 cho ng\u01B0\u1EDDi
    h\u01B0\u1EDBng d\u1EABn vi\xEAn."
  objectiveSolveRadio: "Gi\u1EA3i m\xE3 chi\u1EBFc radio l\u1ECBch s\u1EED."
  objectiveReturnBus: "\u0110i \u0111\u1EBFn tr\u1EA1m xe bu\xFDt k\xFD \u1EE9c \u0111\u1EC3
    quay l\u1EA1i Hub."
  npcMainDialogue: "M\u1ED7i c\u0103n ph\xF2ng, m\u1ED7i hi\u1EC7n v\u1EADt n\u01A1i
    \u0111\xE2y \u0111\u1EC1u gi\u1EEF m\u1ED9t ph\u1EA7n l\u1ECBch s\u1EED. Nh\u01B0ng
    c\xE1c d\xF2ng s\u1EF1 ki\u1EC7n \u0111\xE3 b\u1ECB \u0111\u1EA3o l\u1ED9n, khi\u1EBFn
    \u0111\xE0i radio b\u1ECB nhi\u1EC5u s\xF3ng."
  restoredDialogue: "\u0110\xE0i radio ho\u1EA1t \u0111\u1ED9ng tr\u1EDF l\u1EA1i.
    S\u01B0\u01A1ng m\xF9 tan d\u1EA7n. Dinh \u0110\u1ED9c L\u1EADp \u0111\xE3 \u0111\u01B0\u1EE3c
    kh\xF4i ph\u1EE5c."
