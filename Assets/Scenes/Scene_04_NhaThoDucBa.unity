  m_Script: {fileID: 11500000, guid: 330dd00c876739649aed1fa49dbcbe21, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NhaThoDucBaSceneController
  memoryZone: {fileID: 970332955}
  pigeonFeederNpc: {fileID: 143581782}
  smallBellItem: {fileID: 338981604}
  bellPuzzle: {fileID: 1995049261}
  returnBusStop: {fileID: 1464718183}
  objectiveStart: "\u0110i v\xE0o qu\u1EA3ng tr\u01B0\u1EDDng v\xE0 t\xECm kho\u1EA3ng
    l\u1EB7ng b\u1ECB \u0111\xE1nh m\u1EA5t."
  objectiveFindBell: "T\xECm chi\u1EBFc chu\xF4ng nh\u1ECF quanh qu\u1EA3ng tr\u01B0\u1EDDng."
  objectiveReturnBell: "Mang chi\u1EBFc chu\xF4ng v\u1EC1 cho c\u1EE5 gi\xE0."
  objectiveSolvePuzzle: "Gi\u1EA3i c\xE2u \u0111\u1ED1 th\u1EE9 t\u1EF1 chu\xF4ng."
  objectiveReturnBus: "\u0110i \u0111\u1EBFn tr\u1EA1m xe bu\xFDt k\xFD \u1EE9c \u0111\u1EC3
    quay l\u1EA1i Hub."
  firstNpcDialogue: "Ti\u1EBFng chu\xF4ng nh\xE0 th\u1EDD t\u1EEBng d\u1EABn b\u1EA7y
    b\u1ED3 c\xE2u bay v\u1EC1 m\u1ED7i chi\u1EC1u. Nh\u01B0ng gi\u1EDD m\u1ECDi
    th\u1EE9 \u0111\xE3 im l\u1EB7ng."
  secondNpcDialogue: "\u0110\xFAng r\u1ED3i... \xE2m thanh n\xE0y t\u1EEBng thu\u1ED9c
    v\u1EC1 n\u01A1i \u0111\xE2y. H\xE3y \u0111\xE1nh th\u1EE9c h\xF2a \xE2m c\u1EE7a
    th\xE1p chu\xF4ng."
  restoredDialogue: "Ti\u1EBFng chu\xF4ng vang l\xEAn. B\u1EA7y b\u1ED3 c\xE2u c\u1EA5t
    c\xE1nh. Nh\xE0 th\u1EDD \u0110\u1EE9c B\xE0 \u0111\xE3 \u0111\u01B0\u1EE3c kh\xF4i
    ph\u1EE5c."
