  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BachDangSceneController
  memoryZone: {fileID: 313187261}
  boatmanNpc: {fileID: 393320405}
  oldFerryTicketItem: {fileID: 931708740}
  riverPuzzle: {fileID: 1770623151}
  returnBusStop: {fileID: 1617590802}
  objectiveStart: "\u0110i d\u1ECDc b\u1EBFn s\xF4ng v\xE0 t\xECm k\xFD \u1EE9c b\u1ECB
    m\u1EAFc k\u1EB9t."
  objectiveFindTicket: "T\xECm chi\u1EBFc v\xE9 t\xE0u c\u0169."
  objectiveReturnTicket: "Mang chi\u1EBFc v\xE9 v\u1EC1 cho b\xE1c l\xE1i t\xE0u."
  objectiveSolvePuzzle: "Gi\u1EA3i c\xE2u \u0111\u1ED1 v\u01B0\u1EE3t lu\u1ED3ng
    s\u01B0\u01A1ng m\xF9."
  objectiveReturnBus: "\u0110i \u0111\u1EBFn tr\u1EA1m xe bu\xFDt k\xFD \u1EE9c \u0111\u1EC3
    quay l\u1EA1i Hub."
  firstNpcDialogue: "D\xF2ng s\xF4ng n\xE0y t\u1EEBng ch\u1EDF theo r\u1EA5t nhi\u1EC1u
    c\xE2u chuy\u1EC7n. Nh\u01B0ng h\xF4m nay n\u01B0\u1EDBc \u0111\u1EE9ng y\xEAn,
    c\xF2n nh\u1EEFng con t\xE0u th\xEC kh\xF4ng th\u1EC3 r\u1EDDi b\u1EBFn."
  secondNpcDialogue: "\u0110\xFAng r\u1ED3i... chi\u1EBFc v\xE9 n\xE0y t\u1EEBng
    thu\u1ED9c v\u1EC1 m\u1ED9t h\xE0nh tr\xECnh. H\xE3y gi\xFAp t\xF4i khai th\xF4ng
    d\xF2ng ch\u1EA3y."
  restoredDialogue: "D\xF2ng s\xF4ng chuy\u1EC3n \u0111\u1ED9ng tr\u1EDF l\u1EA1i.
    B\u1EBFn B\u1EA1ch \u0110\u1EB1ng \u0111\xE3 \u0111\u01B0\u1EE3c kh\xF4i ph\u1EE5c."
