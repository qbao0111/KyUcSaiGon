  employeeCardItem: {fileID: 713178817}
  securityPuzzle: {fileID: 1624880580}
  returnBusStop: {fileID: 1320702301}
  objectiveStart: "\u0110i v\xE0o qu\u1EA3ng tr\u01B0\u1EDDng Bitexco v\xE0 t\xECm
    d\u1EA5u v\u1EBFt c\u1EE7a nh\u1ECBp s\u1ED1ng hi\u1EC7n \u0111\u1EA1i."
  objectiveUseCard: "Qu\xE9t th\u1EBB t\u1EA1i khu v\u1EF1c an ninh."
  objectiveSolvePuzzle: "Gi\u1EA3i m\xE3 h\u1EC7 th\u1ED1ng m\xE1y ch\u1EE7 trung
    t\xE2m."
  objectiveReturnBus: "\u0110i \u0111\u1EBFn tr\u1EA1m xe bu\xFDt k\xFD \u1EE9c \u0111\u1EC3
    quay l\u1EA1i Hub."
  npcDialogue: "T\xF4i c\u1EE9 ngh\u0129 ch\u1EC9 c\u1EA7n ch\u1EA1y th\u1EADt nhanh
    l\xE0 \u0111\u1EE7. Nh\u01B0ng khi h\u1EC7 th\u1ED1ng \u0111i\u1EC7n v\u1EE5t
    t\u1EAFt, t\xF4i qu\xEAn m\u1EA5t l\xFD do m\xECnh b\u1EAFt \u0111\u1EA7u."
  restoredDialogue: "H\u1EC7 th\u1ED1ng \u0111i\u1EC7n kh\u1EDFi \u0111\u1ED9ng l\u1EA1i.
    Bitexco s\xE1ng l\xEAn gi\u1EEFa b\u1EA7u tr\u1EDDi S\xE0i G\xF2n."
